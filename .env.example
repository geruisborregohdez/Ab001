# Copy to .env and fill in your values

# LLM provider: groq (default, free tier) | claude
AGENT_PROVIDER=groq

# Groq API key — get a free key at console.groq.com
GROQ_API_KEY=gsk_...

# Groq model (optional)
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude API key (only needed if AGENT_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Database URL — SQLite default. Change to RDS PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/ab001
DATABASE_URL=sqlite+aiosqlite:///./data/ab001.db

# QuickBooks integration mode: stub | real
QB_MODE=stub

# QuickBooks real integration (only needed if QB_MODE=real)
# Get these from Intuit Developer portal -> your app -> Keys & credentials
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=
QB_ACCESS_TOKEN=        # optional pre-seeded; auto-refreshed if blank/expired
QB_DEFAULT_ITEM_REF=1   # QB Item ID for invoice line items (1 = Services in default QB company)
QB_ENVIRONMENT=sandbox  # sandbox or production
# Must be registered in Intuit Developer Console -> your app -> Redirect URIs
# For EC2: http://<your-ec2-ip>/api/auth/quickbooks/callback
# For production: https://<your-domain>/api/auth/quickbooks/callback
QB_REDIRECT_URI=

# Claude model to use (optional, only if AGENT_PROVIDER=claude)
CLAUDE_MODEL=claude-sonnet-4-6

# Frontend → backend URL (set in docker-compose, override if needed)
BACKEND_URL=http://backend:8000
